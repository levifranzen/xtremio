# Copie este arquivo para .env e atualize os valores sensíveis antes de rodar o compose
# NÃO comite o arquivo .env com chaves reais para o repositório

# Chave Fernet usada para criptografia/decriptação das configurações
# Você pode gerar uma chave segura com: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=INSIRA_SUA_CHAVE_AQUI

# Chave de API do TMDB (opcional) — usada para buscar metadados por IMDB id
TMDB_API_KEY=INSIRA_SUA_CHAVE_AQUI
